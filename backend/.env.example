# MongoDB Configuration
MONGO_URL="mongodb://localhost:27017"
DB_NAME="test_database"
CORS_ORIGINS="*"

# Email Configuration (SMTP)
# För Gmail: Använd App Password från https://myaccount.google.com/apppasswords
# För andra leverantörer: Använd deras SMTP-inställningar
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=din.email@gmail.com
SMTP_PASSWORD=ditt-app-lösenord-här
EMAIL_FROM=din.email@gmail.com
EMAIL_TO=hej@aiweb.se

# Instruktioner:
# 1. Kopiera denna fil till .env
# 2. Fyll i dina riktiga värden
# 3. Ändra EMAIL_TO till din email där du vill få kontaktförfrågningar
